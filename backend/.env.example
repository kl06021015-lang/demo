# DeepSeek API (对话、纠错、课后总结)
# 从 https://platform.deepseek.com/api_keys 获取
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 讯飞语音识别（语音转文字）
# 从 https://console.xfyun.cn/ 创建应用获取
XFYUN_APP_ID=your-app-id-here
XFYUN_API_KEY=your-api-key-here
XFYUN_API_SECRET=your-api-secret-here
